# Kopier til .env og fyll inn verdier

# Git-identitet
GIT_AUTHOR_NAME=Fornavn Etternavn
GIT_AUTHOR_EMAIL=bruker@eksempel.no

# Ollama-modell som skal brukes for RoS-vurdering
# Finn tilgjengelige modeller: ollama list
OLLAMA_MODEL=llama3.3

# SOPS: GCP KMS-nøkkel (service account JSON)
# GCP_CREDENTIALS_FILE=/Users/deg/.config/gcp/ros-sops-sa.json

# SOPS: age-nøkkel
# AGE_KEY_FILE=/Users/deg/.config/age/ros.key
